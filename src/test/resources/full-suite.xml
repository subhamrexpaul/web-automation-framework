<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Full Parallel Test Suite" parallel="tests" thread-count="3" verbose="1">
    <listeners>
        <listener class-name="com.webautomation.reports.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.webautomation.tests.LoginTests"/>
        </classes>
    </test>

    <test name="Home Page Tests">
        <classes>
            <class name="com.webautomation.tests.HomePageTests"/>
        </classes>
    </test>

    <test name="Product Tests">
        <classes>
            <class name="com.webautomation.tests.ProductTests"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.webautomation.tests.CartTests"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.webautomation.tests.CheckoutTests"/>
        </classes>
    </test>

    <test name="Search & Filter Tests">
        <classes>
            <class name="com.webautomation.tests.SearchTests"/>
        </classes>
    </test>
</suite>
