<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" verbose="1">
    <listeners>
        <listener class-name="com.webautomation.reports.TestListener"/>
    </listeners>

    <test name="Login Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.webautomation.tests.LoginTests"/>
        </classes>
    </test>

    <test name="Homepage Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.webautomation.tests.HomePageTests"/>
        </classes>
    </test>

    <test name="Cart Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.webautomation.tests.CartTests"/>
        </classes>
    </test>

    <test name="Checkout Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.webautomation.tests.CheckoutTests"/>
        </classes>
    </test>
</suite>
